<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="Library_Managment_App.Views.MemberViews.MyLoansView">

	<Border Background="#C5B8A1" CornerRadius="10" Padding="16" Margin="0,8,0,0">
		<StackPanel Spacing="6">
			<TextBlock Text="Active Loans" FontSize="20" FontWeight="Bold"/>
			<TextBlock Text="No active loans yet." FontSize="14"/>
		</StackPanel>
	</Border>
</UserControl>
