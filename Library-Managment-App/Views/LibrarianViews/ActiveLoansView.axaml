<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Library_Managment_App.ViewModels"
			 x:Class="Library_Managment_App.Views.LibrarianViews.ActiveLoansView"
			 x:DataType="vm:ActiveLoansViewModel"
			 x:CompileBindings="False">

	<Border Background="#8A8E75" BorderBrush="#BEC5A4" BorderThickness="2" CornerRadius="10" Padding="16" Margin="0,8,0,0">
		<StackPanel Spacing="10">
			<TextBlock Text="Active Loans" FontSize="20" FontWeight="Bold"/>

			<TextBlock IsVisible="{Binding NoActiveLoans}" Text="No active loans are currently registered." FontSize="14"/>

			<ListBox IsVisible="{Binding HasActiveLoans}" ItemsSource="{Binding ActiveLoans}">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="10">
							<StackPanel Spacing="2">
								<TextBlock Text="{Binding BookTitle}" FontWeight="SemiBold"/>
								<TextBlock Text="{Binding BookIsbn, StringFormat='ISBN: {0}'}" FontSize="12"/>
							</StackPanel>
							<TextBlock Grid.Column="1" Text="{Binding MemberName, StringFormat='Borrowed by: {0}'}"/>
							<TextBlock Grid.Column="2" Text="{Binding BorrowedAtText}" FontSize="12" VerticalAlignment="Center"/>
						</Grid>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
		</StackPanel>
	</Border>
</UserControl>
