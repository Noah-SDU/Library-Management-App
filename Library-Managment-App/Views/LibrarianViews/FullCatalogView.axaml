<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Library_Managment_App.Views.LibrarianViews.FullCatalogView">

    <Border Background="#8A8E75" BorderBrush="#BEC5A4" BorderThickness="2" CornerRadius="10" Padding="16" Margin="0,8,0,0">
        <StackPanel Spacing="10">
            <TextBlock Text="Full Catalog" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Add and manage books in the library catalog." FontSize="14"/>

            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="10" Margin="0,6,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Title" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Watermark="Book title"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Author" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Watermark="Author name"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="ISBN" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Watermark="ISBN"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Copies" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" Watermark="Number of copies"/>
            </Grid>

            <Button Content="Add Book" HorizontalAlignment="Left" Padding="14,6"/>

            <Border Background="#BEC5A4" BorderBrush="#C5B8A1" BorderThickness="1" CornerRadius="8" Padding="12">
                <TextBlock Text="Catalog entries will appear here."/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
