<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Library_Managment_App.ViewModels"
             x:Class="Library_Managment_App.Views.LibrarianViews.FullCatalogView"
             x:DataType="vm:LibrarianCatalogViewModel"
             x:CompileBindings="False">

    <Border Background="#8A8E75" BorderBrush="#BEC5A4" BorderThickness="2" CornerRadius="10" Padding="16" Margin="0,8,0,0">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="10">
            <TextBlock Grid.Row="0" Text="Full Catalog" FontSize="20" FontWeight="Bold"/>
            <TextBlock Grid.Row="1" Text="Add and manage books in the library catalog." FontSize="14"/>

            <Grid Grid.Row="2" ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="10" Margin="0,6,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Title" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NewTitle}" Watermark="Book title"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Author" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewAuthor}" Watermark="Author name"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="ISBN" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewIsbn}" Watermark="ISBN"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Copies" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding NewCopiesText}" Watermark="Number of copies"/>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                <Button Content="Add Book" Command="{Binding AddBookCommand}" HorizontalAlignment="Left" Padding="14,6"/>
                <Button Content="Save Changes" Command="{Binding EditSelectedBookCommand}" HorizontalAlignment="Left" Padding="14,6"/>
                <Button Content="Delete Selected" Command="{Binding DeleteSelectedBookCommand}" HorizontalAlignment="Left" Padding="14,6"/>
            </StackPanel>

            <Grid Grid.Row="4" RowDefinitions="Auto,*" RowSpacing="10">
                <StackPanel Grid.Row="0" Spacing="2">
                    <TextBlock Text="Select a catalog entry to load it into the form, then click Save Changes." FontSize="12"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#BEC5A4" BorderBrush="#C5B8A1" BorderThickness="1" CornerRadius="8" Padding="12" MinHeight="220" MaxHeight="320">
                    <Grid RowDefinitions="Auto,*" RowSpacing="8">
                        <TextBlock Grid.Row="0" Text="Catalog entries" FontWeight="SemiBold"/>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding LibrarianCatalogBooks}"
                                 SelectedItem="{Binding SelectedLibrarianBook}"
                                 SelectionMode="Multiple,Toggle"
                                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Author}" FontSize="13"/>
                                            <TextBlock Text="{Binding ISBN, StringFormat='ISBN: {0}'}" FontSize="12"/>
                                            <TextBlock Text="{Binding AverageRatingText}" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding CopiesText}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
